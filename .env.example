# ===========================================
# HiGolang 环境变量配置
# 复制此文件为 .env 并修改对应值
# cp .env.example .env
# ===========================================

# 站点域名
DOMAIN=free.higolang.vip

# SSL 证书路径（容器内路径）
# 配置后自动启用 HTTPS，留空则仅启用 HTTP
SSL_CERT=/etc/nginx/ssl/fullchain.pem
SSL_KEY=/etc/nginx/ssl/privkey.pem
